type [Nat] : Z | S [Nat] .
type [Bool] : True | False .

<< 1. Классическое сложение (add) >>
fun (add [Nat] [Nat]) -> [Nat] :
    (add [Z] y) -> y
  | (add [S x] y) -> [S (add x y)] .

<< 2. Сложение с аккумулятором (addAcc) >>
<< Это "плохая" функция для суперкомпилятора: второй аргумент растет >>
fun (addAcc [Nat] [Nat]) -> [Nat] :
    (addAcc [Z] y) -> y
  | (addAcc [S x] y) -> (addAcc x [S y]) .

<< 3. Сравнение чисел (eq) >>
fun (eq [Nat] [Nat]) -> [Bool] :
    (eq [Z] [Z]) -> [True]
  | (eq [S x] [S y]) -> [False]
  | (eq [S x] [S y]) -> (eq x y) .

<< 4а. Умножение чисел >>
fun (mul1 [Nat] [Nat]) -> [Nat]:
    (mul1 [Z] y) -> [Z]
  | (mul1 [S x] y) -> (add y (mul1 x y)).

<< 4б. Умножение чисел >>
fun (mul2 [Nat] [Nat]) -> [Nat]:
    (mul2 [Z] y) -> [Z]
  | (mul2 [S x] y) -> (add (mul2 x y) y).

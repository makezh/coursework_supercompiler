digraph ProcessTree {
  label="Expression: fab\nWhistle Strategy: HE | Gen Type: TOP";
  labelloc="t";
  fontsize=20;
  fontname="Arial";

    node [fontname="Courier New"];
    edge [fontname="Courier New"];
    n0 [label="(fab x1)", shape=box];
    n0 -> n1 [label="x1 -> (Cons v1 v2)"];
    n0 -> n2 [label="x1 -> (Cons v3 v4)"];
    n0 -> n3 [label="x1 -> (Nil )"];
    n1 [label="(fab [Cons v1 v2])", shape=box];
    n1 -> n4 [label=""];
    n2 [label="(fab [Cons v3 v4])", shape=box];
    n2 -> n5 [label=""];
    n3 [label="(fab [Nil])", shape=box];
    n3 -> n6 [label=""];
    n4 [label="[Cons v1 (fab v2)]", shape=box];
    n4 -> n7 [label=""];
    n4 -> n8 [label=""];
    n5 [label="[Cons v3 (fab v4)]", shape=box];
    n5 -> n9 [label=""];
    n5 -> n10 [label=""];
    n6 [label="[Nil]", shape=box];
    n7 [label="v1", shape=box];
    n8 [label="(fab v2)", shape=box];
    n8 -> n0 [style=dashed, color=red, label="Folding"];
    n9 [label="v3", shape=box];
    n10 [label="(fab v4)", shape=box];
    n10 -> n0 [style=dashed, color=red, label="Folding"];
}
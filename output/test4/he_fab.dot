digraph ProcessTree {
  label="Expression: fab\nWhistle Strategy: HE | Gen Type: TOP";
  labelloc="t";
  fontsize=20;
  fontname="Arial";

    node [fontname="Courier New"];
    edge [fontname="Courier New"];
    start [label="(fab x1)", shape=box, style="filled", fillcolor="lightgreen", color="darkgreen", penwidth=2.0];
    start -> n0 [];
    n0 [label="(fab x1)", shape=box];
    n0 -> n1 [label="x1 -> [Cons [A] v2]"];
    n0 -> n2 [label="x1 -> [Cons v3 v4]"];
    n0 -> n3 [label="x1 -> [Nil]"];
    n1 [label="[Cons [B] (fab v2)]", shape=box];
    n1 -> n4 [label=""];
    n1 -> n5 [label=""];
    n2 [label="[Cons v3 (fab v4)]", shape=box];
    n2 -> n6 [label=""];
    n2 -> n7 [label=""];
    n3 [label="[Nil]", shape=box];
    n4 [label="[B]", shape=box];
    n5 [label="(fab v2)", shape=box];
    n5 -> n0 [style=dashed, color=red, label="Folding"];
    n6 [label="v3", shape=box];
    n7 [label="(fab v4)", shape=box];
    n7 -> n0 [style=dashed, color=red, label="Folding"];
}
digraph ProcessTree {
  label="Expression: xeqx1\nWhistle Strategy: TAG | Gen Type: TOP";
  labelloc="t";
  fontsize=20;
  fontname="Arial";

    node [fontname="Courier New"];
    edge [fontname="Courier New"];
    n0 [label="(eq x1 [S x1])", shape=box];
    n0 -> n1 [label="x1 -> (Z )"];
    n0 -> n2 [label="x1 -> (S v1)"];
    n1 [label="[False]", shape=box];
    n2 [label="(eq v1 [S v1])", shape=box];
    n2 -> n3 [label="v1 -> (Z )"];
    n2 -> n4 [label="v1 -> (S v2)"];
    n3 [label="[False]", shape=box];
    n4 [label="(eq v2 [S v2])", shape=box];
    n4 -> n2 [style=dashed, color=red, label="Folding"];
}
digraph ProcessTree {
  label="Expression: eqlists\nWhistle Strategy: HE | Gen Type: TOP";
  labelloc="t";
  fontsize=20;
  fontname="Arial";

    node [fontname="Courier New"];
    edge [fontname="Courier New"];
    start [label="(eqlists x1 x2)", shape=box, style="filled", fillcolor="lightgreen", color="darkgreen", penwidth=2.0];
    start -> n0 [];
    n0 [label="(eqlists x1 x2)", shape=box];
    n0 -> n1 [label="x1 -> [Cons [A] v2], x2 -> [Cons [A] v4]"];
    n0 -> n2 [label="x1 -> [Cons [B] v6], x2 -> [Cons [B] v8]"];
    n0 -> n3 [label="x1 -> [Cons [C] v10], x2 -> [Cons [C] v12]"];
    n0 -> n4 [label="x1 -> [Cons [D] v14], x2 -> [Cons [D] v16]"];
    n0 -> n5 [label="x1 -> [Nil], x2 -> [Nil]"];
    n0 -> n6 [label="default"];
    n1 [label="(eqlists v2 v4)", shape=box];
    n1 -> n0 [style=dashed, color=red, label="Folding"];
    n2 [label="(eqlists v6 v8)", shape=box];
    n2 -> n0 [style=dashed, color=red, label="Folding"];
    n3 [label="(eqlists v10 v12)", shape=box];
    n3 -> n0 [style=dashed, color=red, label="Folding"];
    n4 [label="(eqlists v14 v16)", shape=box];
    n4 -> n0 [style=dashed, color=red, label="Folding"];
    n5 [label="[True]", shape=box];
    n6 [label="[False]", shape=box];
}
    n0 -> n2 [label="x1 -> (S v1)"];
    n1 [label="(addAcc [Z] x2)", shape=box];
    n1 -> n3 [label=""];
    n2 [label="(addAcc [S v1] x2)", shape=box];
    n2 -> n4 [label=""];

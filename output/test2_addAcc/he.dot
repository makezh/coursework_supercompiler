digraph ProcessTree {
  label="Expression: addAcc\nWhistle Strategy: HE | Gen Type: TOP";
  labelloc="t";
  fontsize=20;
  fontname="Arial";

    node [fontname="Courier New"];
    edge [fontname="Courier New"];
    n0 [label="(addAcc x1 x2)", shape=box];
    drv1 [label="DRIVE\n(addAcc [Z] y)", shape=ellipse, style="filled", fillcolor="lavender"];
    n0 -> drv1 [label="x1 -> (Z )"];
    drv1 -> n1 [label="x1 -> (Z )"];
    drv2 [label="DRIVE\n(addAcc [S x] y)", shape=ellipse, style="filled", fillcolor="lavender"];
    n0 -> drv2 [label="x1 -> (S v1)"];
    drv2 -> n2 [label="x1 -> (S v1)"];
    n1 [label="x2", shape=box];
    n2 [label="(addAcc v1 [S x2])", shape=box];
    n2 -> n0 [style=dashed, color=red, label="Folding"];
}
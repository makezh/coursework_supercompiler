digraph ProcessTree {
  label="Expression: (addAcc v1 y)\nWhistle Strategy: HE | Gen Type: TOP";
  labelloc="t";
  fontsize=20;
  fontname="Arial";

    node [fontname="Courier New"];
    edge [fontname="Courier New"];
    n0 [label="(addAcc v1 y)", shape=box];
    n0 -> n1 [label="v1 -> (Z )"];
    n0 -> n2 [label="v1 -> (S v1)"];
    n1 [label="y", shape=box];
    n2 [label="(addAcc v1 [S y])", shape=box];
    n2 -> n0 [style=dashed, color=red, label="Folding"];
}
digraph ProcessTree {
  label="Expression: addAcc\nWhistle Strategy: TAG | Gen Type: TOP";
  labelloc="t";
  fontsize=20;
  fontname="Arial";

    node [fontname="Courier New"];
    edge [fontname="Courier New"];
    n0 [label="(addAcc x1 x2)", shape=box];
    n0 -> n1 [label="x1 -> (Z )"];
    n0 -> n2 [label="x1 -> (S v1)"];
    n1 [label="x2", shape=box];
    n2 [label="(addAcc v1 [S x2])", shape=box];
    n2 -> n3 [label="v1 -> (Z )"];
    n2 -> n4 [label="v1 -> (S v2)"];
    n3 [label="[S x2]", shape=box];
    n3 -> n5 [label=""];
    n4 [label="(addAcc v2 [S [S x2]])", shape=box];
    n4 -> n2 [style=dashed, color=red, label="Folding"];
    n5 [label="x2", shape=box];
}
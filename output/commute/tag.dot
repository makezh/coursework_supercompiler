digraph ProcessTree {
  label="Expression: main\nWhistle Strategy: TAG | Gen Type: TOP";
  labelloc="t";
  fontsize=20;
  fontname="Arial";

    node [fontname="Courier New"];
    edge [fontname="Courier New"];
    start [label="(main x1)", shape=box, style="filled", fillcolor="lightgreen", color="darkgreen", penwidth=2.0];
    start -> n0 [];
    n0 [label="(eq (add x1 [S [Z]]) (add [S [Z]] x1))", shape=box];
    n0 -> n1 [label="x1 -> [S v1]\nMSG\nα: (eq (add v1 [S [Z]]) v2)\n→ (eq v1 v2)", color="darkorange", fontcolor="black", fontsize=10];
    n0 -> n2 [label="x1 -> [Z]"];
    n1 [label="(eq v1 v2)", shape=box];
    n1 -> n3 [label="let v1 = (add v1 [S [Z]])"];
    n1 -> n4 [label="v1 -> [Z], v2 -> [Z]"];
    n1 -> n5 [label="v1 -> [S v6], v2 -> [S v7]"];
    n1 -> n6 [label="default"];
    n2 [label="[True]", shape=box];
    n3 [label="(add v1 [S [Z]])", shape=box];
    n3 -> n7 [label="v1 -> [S v8]"];
    n3 -> n8 [label="v1 -> [Z]"];
    n4 [label="[True]", shape=box];
    n5 [label="(eq v6 v7)", shape=box];
    n5 -> n1 [style=dashed, color=red, label="Folding"];
    n6 [label="[False]", shape=box];
    n7 [label="[S (add v8 [S [Z]])]", shape=box];
    n7 -> n9 [label=""];
    n8 [label="[S [Z]]", shape=box];
    n8 -> n10 [label=""];
    n9 [label="(add v8 [S [Z]])", shape=box];
    n9 -> n3 [style=dashed, color=red, label="Folding"];
    n10 [label="[Z]", shape=box];
}
digraph ProcessTree {
  label="Expression: main\nWhistle Strategy: TAG | Gen Type: TOP";
  labelloc="t";
  fontsize=20;
  fontname="Arial";

    node [fontname="Courier New"];
    edge [fontname="Courier New"];
    n0 [label="(eq (add x1 [S [Z]]) (add [S [Z]] x1))", shape=box];
    n0 -> n1 [label="x1 -> (S v1)"];
    n0 -> n2 [label="x1 -> (Z )"];
    n1 [label="(eq (add v1 [S [Z]]) (add [Z] [S v1]))", shape=box];
    n1 -> n3 [label="v1 -> (S v2)"];
    n1 -> n4 [label="v1 -> (Z )"];
    n2 [label="[True]", shape=box];
    n3 [label="(eq (add v2 [S [Z]]) [S v2])", shape=box];
    n3 -> n5 [label="v2 -> (S v3)"];
    n3 -> n6 [label="v2 -> (Z )"];
    n4 [label="[True]", shape=box];
    n5 [label="(eq (add v3 [S [Z]]) [S v3])", shape=box];
    n5 -> n3 [style=dashed, color=red, label="Folding"];
    n6 [label="[True]", shape=box];
}
digraph ProcessTree {
  label="Expression: mul1\nWhistle Strategy: HE | Gen Type: TOP";
  labelloc="t";
  fontsize=20;
  fontname="Arial";

    node [fontname="Courier New"];
    edge [fontname="Courier New"];
    n0 [label="(mul1 x1 x2)", shape=box];
    n0 -> n1 [label="x1 -> (Z )"];
    n0 -> n2 [label="x1 -> (S v1)"];
    n1 [label="[Z]", shape=box];
    n2 [label="(let h1 = x2; h2 = (mul1 v1 x2) in (add h1 h2))", shape=box, style="filled", fillcolor="lightyellow", color="orange", penwidth=2.0];
    n2 -> n3 [label=""];
    n2 -> n4 [label=""];
    n2 -> n5 [label=""];
    n3 [label="x2", shape=box];
    n4 [label="(mul1 v1 x2)", shape=box];
    n4 -> n0 [style=dashed, color=red, label="Folding"];
    n5 [label="(add h1 h2)", shape=box];
}
digraph ProcessTree {
  label="Expression: mul2\nWhistle Strategy: HE | Gen Type: BOTTOM";
  labelloc="t";
  fontsize=20;
  fontname="Arial";

    node [fontname="Courier New"];
    edge [fontname="Courier New"];
    n0 [label="(PROGRAM_FOREST )", shape=box];
    n0 -> n1 [label=""];
    n1 [label="(mul2 x1 x2)", shape=box];
    n1 -> n2 [label="x1 -> (Z )"];
    n1 -> n3 [label="x1 -> (S v1)"];
    n2 [label="[Z]", shape=box];
    n3 [label="(let h1 = (mul2 v1 x2); h2 = x2 in (add h1 h2))", shape=box, style="filled", fillcolor="lightyellow", color="orange", penwidth=2.0];
    n3 -> n4 [label=""];
    n3 -> n5 [label=""];
    n3 -> n6 [label=""];
    n4 [label="(mul2 v1 x2)", shape=box];
    n4 -> n1 [style=dashed, color=red, label="Folding"];
    n5 [label="x2", shape=box];
    n6 [label="(add h1 h2)", shape=box];
}